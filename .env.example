# =====================================================================
# UnterlagenPilot – Beispiel-Umgebungsvariablen
# Kopiere zu .env  (Prisma UND Next.js lesen .env; Next liest zusätzlich
# .env.local). NIE echte Zugangsdaten committen.
# =====================================================================

# --- Datenbank (PostgreSQL / Supabase) ---
# Supabase -> Project Settings -> Database -> Connection string:
#   DATABASE_URL = "Transaction"-Pooler (Port 6543, ?pgbouncer=true) für die App
#   DIRECT_URL   = "Session"/Direkt-Verbindung (Port 5432) für Migrationen
# Lokal (docker-compose) beide auf localhost:5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/unterlagenpilot?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/unterlagenpilot?schema=public"

# --- App ---
APP_BASE_URL="http://localhost:3000"
# Geheimnisse (mind. 16, besser 32+ Zeichen). Auf Vercel als Env-Variablen setzen.
AUTH_SECRET="change-me-to-a-long-random-secret-string-min-32"
UPLOAD_TOKEN_SECRET="change-me-to-a-second-long-random-secret-string"

# --- Storage ---
# local = In-Memory (nur Dev/Demo). Produktiv: supabase oder s3.
STORAGE_PROVIDER="local"          # local | supabase | s3
STORAGE_BUCKET="unterlagenpilot"
# Supabase Storage (Service-Role-Key NUR serverseitig verwenden!)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# Generisch S3-kompatibel (optional)
S3_ENDPOINT=""
S3_REGION="eu-central-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# --- AI Provider (NUR EU-/DSGVO-konform produktiv einsetzen) ---
AI_PROVIDER="mock"                # mock | azure-openai | openai-compatible
# Variante A: Azure OpenAI in EU-Region (Sweden Central / France Central / Germany West Central)
AZURE_OPENAI_ENDPOINT=""          # https://<resource>.openai.azure.com  (EU-Region!)
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT=""        # Name des Deployments, z.B. gpt-4o-eu
AZURE_OPENAI_API_VERSION="2024-10-21"
# Variante B: EU-OpenAI-kompatibel, z.B. Mistral AI (Frankreich)
OPENAI_COMPATIBLE_BASE_URL=""     # z.B. https://api.mistral.ai/v1
OPENAI_COMPATIBLE_API_KEY=""
OPENAI_COMPATIBLE_MODEL=""        # z.B. mistral-large-latest

# --- OCR Provider ---
OCR_PROVIDER="mock"               # mock | azure-document-intelligence | tesseract
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=""
AZURE_DOCUMENT_INTELLIGENCE_KEY=""

# --- Plattform-Connectoren (Stubs – keine echten Endpunkte erraten) ---
FINLINK_BASE_URL=""
FINLINK_API_KEY=""
EUROPACE_BASE_URL=""
EUROPACE_CLIENT_ID=""
EUROPACE_CLIENT_SECRET=""
EHYP_BASE_URL=""
EHYP_API_KEY=""
EHYP_CLIENT_ID=""
EHYP_CLIENT_SECRET=""
EHYP_COMPANY_ID=""

# --- Datenschutz / Aufbewahrung ---
DEFAULT_RETENTION_DAYS="0"        # 0 = bis manuelle Löschung
